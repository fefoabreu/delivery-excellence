# Delivery Excellence — backend environment
# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# Optional. If set, the AI agent (chat / SLW drafting / health analysis) uses the
# Anthropic SDK with this key. If left unset, the agent falls back to the local
# Claude Code CLI (`claude -p`), which needs no key.
ANTHROPIC_API_KEY=
